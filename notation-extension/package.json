{
  "main": "dist/extension.cjs",
  "scripts": {
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "fix": "biome check --write src",
    "check": "npm run typecheck && npm run format:check && npm run lint && npm test",
    "package": "npm run build:prod && extensions-cli package . -o Notation-1.0.0.ablx"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:../extensions-sdk/ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "opensheetmusicdisplay": "^1.8.9",
    "preact": "^10.25.4"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:../extensions-sdk/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@biomejs/biome": "2.4.12",
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.10",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}